# ── Supabase (frontend) ──────────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase (server / cron) ─────────────────────────────────────────────────
# Use the SERVICE ROLE key (never expose this to the browser)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Arkesel SMS (Ghana) ───────────────────────────────────────────────────────
# Get API key from: arkesel.com → Dashboard → API Keys
ARKESEL_API_KEY=your-arkesel-api-key-here
ARKESEL_SENDER_ID=GymUp

# ── Vercel Cron Security ──────────────────────────────────────────────────────
# Any random string — Vercel sends this automatically on cron calls
# Generate one at: https://generate-secret.vercel.app/32
CRON_SECRET=your-random-secret-here
